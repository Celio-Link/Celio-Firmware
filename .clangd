CompileFlags:
  Remove: [
    -fno-reorder-functions,
    -fno-plt,
    -fdiagnostics-color,
    -fno-omit-frame-pointer,
    -fno-strict-overflow,
    -fno-var-tracking-assignments,
    -mfp16-format=ieee
  ]

